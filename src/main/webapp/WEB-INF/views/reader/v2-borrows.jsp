<%@ page contentType="text/html;charset=UTF-8" pageEncoding="UTF-8" %><%@ include file="../common/taglib.jsp" %>
<!DOCTYPE html><html><head><meta charset="UTF-8"><title>我的借阅</title><link rel="stylesheet" href="${pageContext.request.contextPath}/assets/css/v2.css"></head><body class="v2-body"><div class="v2-layout"><jsp:include page="v2-header.jsp"/><main class="v2-main">
<div class="v2-top"><div><h1>我的借阅</h1><p>当前借阅、历史借阅、逾期提醒与续借申请。</p></div></div>
<section class="v2-card"><h2>当前借阅</h2><table class="v2-table"><tr><th>图书</th><th>借出日期</th><th>应还日期</th><th>续借次数</th><th>状态</th><th>操作</th></tr><c:forEach items="${currentList}" var="b"><tr><td>${b.bookName}</td><td>${fn:replace(b.borrowDate, 'T', ' ')}</td><td>${fn:replace(b.dueDate, 'T', ' ')}</td><td>${b.renewCount}</td><td><span class="v2-tag ${b.overdueFlag==1?'danger':'ok'}">${b.overdueFlag==1?'逾期':'正常'}</span></td><td><c:if test="${b.overdueFlag!=1}"><form method="post" action="${pageContext.request.contextPath}/reader/v2/renews/apply"><input type="hidden" name="borrowRecordId" value="${b.id}"><input class="v2-input" name="reason" placeholder="续借理由"><button class="v2-btn primary">申请续借</button></form></c:if></td></tr></c:forEach></table></section>
<section class="v2-card"><h2>历史借阅</h2><table class="v2-table"><tr><th>图书</th><th>借出</th><th>归还</th><th>罚款</th><th>状态</th></tr><c:forEach items="${historyList}" var="b"><tr><td>${b.bookName}</td><td>${fn:replace(b.borrowDate, 'T', ' ')}</td><td>${fn:replace(b.returnDate, 'T', ' ')}</td><td>${b.fine}</td><td>${b.status}</td></tr></c:forEach></table></section>
</main></div></body></html>

