<%@ page contentType="text/html;charset=UTF-8" pageEncoding="UTF-8" %><%@ include file="../common/taglib.jsp" %>
<!DOCTYPE html><html><head><meta charset="UTF-8"><title>个人中心</title><link rel="stylesheet" href="${pageContext.request.contextPath}/assets/css/v2.css"></head><body class="v2-body"><div class="v2-layout"><jsp:include page="v2-header.jsp"/><main class="v2-main">
<div class="v2-top"><div><h1>个人中心</h1><p>校园卡式个人资料、头像与联系方式维护。</p></div></div>
<section class="v2-card"><div class="v2-card-id"><img class="v2-avatar" src="${pageContext.request.contextPath}${empty profile.avatar?'/assets/img/default-book.svg':profile.avatar}"><div><h2>${profile.name}</h2><p>读者编号：${profile.readerNo}</p><p>学号：${profile.studentNo}</p><p>学院：${profile.college}</p><p>专业班级：${profile.major} ${profile.className}</p><p>性别：${profile.gender}</p></div></div></section>
<section class="v2-card"><h2>修改联系方式</h2><form class="v2-form" method="post" action="${pageContext.request.contextPath}/reader/v2/profile/update" enctype="multipart/form-data"><div><label>电话</label><input class="v2-input" name="phone" value="${profile.phone}"></div><div><label>邮箱</label><input class="v2-input" name="email" value="${profile.email}"></div><div><label>头像</label><input class="v2-input" type="file" name="avatarFile" accept="image/*"></div><button class="v2-btn primary">保存</button></form></section>
</main></div></body></html>
