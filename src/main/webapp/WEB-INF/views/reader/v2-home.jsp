<%@ page contentType="text/html;charset=UTF-8" pageEncoding="UTF-8" %><%@ include file="../common/taglib.jsp" %>
<!DOCTYPE html><html><head><meta charset="UTF-8"><title>读者首页</title><link rel="stylesheet" href="${pageContext.request.contextPath}/assets/css/v2.css"></head><body class="v2-body"><div class="v2-layout"><jsp:include page="v2-header.jsp"/><main class="v2-main">
<div class="v2-top"><div><h1>读者首页</h1><p>公告、推荐图书、个人借阅提醒。</p></div></div>
<div class="v2-grid-2"><section class="v2-card"><h2>我的校园卡</h2><div class="v2-card-id"><img class="v2-avatar" src="${pageContext.request.contextPath}${empty profile.avatar?'/assets/img/default-book.svg':profile.avatar}"><div><h2>${profile.name}</h2><p>${profile.readerNo} / ${profile.studentNo}</p><p>${profile.college} ${profile.major} ${profile.className}</p><a class="v2-btn primary" href="${pageContext.request.contextPath}/reader/v2/profile">完善资料</a></div></div></section><section class="v2-card"><h2>公告</h2><c:forEach items="${notices}" var="n"><div style="border-bottom:1px solid #e5eaf3;padding:10px 0"><strong>${n.title}</strong><p class="v2-muted">${n.content}</p></div></c:forEach></section></div>
<section class="v2-card"><h2>当前借阅提醒</h2><table class="v2-table"><tr><th>图书</th><th>借出</th><th>应还</th><th>状态</th></tr><c:forEach items="${currentBorrows}" var="b"><tr><td>${b.bookName}</td><td>${fn:replace(b.borrowDate, 'T', ' ')}</td><td>${fn:replace(b.dueDate, 'T', ' ')}</td><td><span class="v2-tag ${b.overdueFlag==1?'danger':'ok'}">${b.overdueFlag==1?'逾期':'正常'}</span></td></tr></c:forEach></table></section>
<section class="v2-card"><h2>推荐图书</h2><div class="v2-book-list"><c:forEach items="${recommendBooks}" var="b"><div class="v2-book"><img src="${pageContext.request.contextPath}${empty b.coverImage?'/assets/img/default-book.svg':b.coverImage}"><h3>${b.bookName}</h3><p class="v2-muted">${b.author} · ${b.categoryName}</p><a class="v2-btn primary" href="${pageContext.request.contextPath}/reader/v2/books/${b.id}">详情</a></div></c:forEach></div></section>
</main></div></body></html>

