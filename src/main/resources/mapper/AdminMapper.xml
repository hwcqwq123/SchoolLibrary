<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="cn.edu.library.mapper.AdminMapper">

    <!-- 【本次修改】管理员字段显式映射 -->
    <resultMap id="AdminResultMap" type="cn.edu.library.entity.Admin">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="realName" column="real_name"/>
        <result property="role" column="role"/>
        <result property="phone" column="phone"/>
        <result property="email" column="email"/>
        <result property="avatar" column="avatar"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <!--
        【本次修改】
        管理员登录 SQL 做兼容：
        1. password = #{password}：支持传入数据库中实际保存的密码
        2. password = MD5(#{password})：支持传入明文密码
        3. 不限制 role，SUPER_ADMIN 和 ADMIN 都能登录
    -->
    <select id="login" resultMap="AdminResultMap">
        SELECT
            id,
            username,
            password,
            real_name,
            role,
            phone,
            email,
            avatar,
            status,
            create_time,
            update_time
        FROM admin
        WHERE username = #{username}
          AND status = 1
          AND (
              password = #{password}
              OR password = MD5(#{password})
              OR password = LOWER(MD5(#{password}))
              OR password = UPPER(MD5(#{password}))
          )
        LIMIT 1
    </select>

    <select id="findByUsername" resultMap="AdminResultMap">
        SELECT
            id,
            username,
            password,
            real_name,
            role,
            phone,
            email,
            avatar,
            status,
            create_time,
            update_time
        FROM admin
        WHERE username = #{username}
        LIMIT 1
    </select>

    <select id="findById" resultMap="AdminResultMap">
        SELECT
            id,
            username,
            password,
            real_name,
            role,
            phone,
            email,
            avatar,
            status,
            create_time,
            update_time
        FROM admin
        WHERE id = #{id}
    </select>

    <update id="updatePassword">
        UPDATE admin
        SET password = #{password},
            update_time = NOW()
        WHERE id = #{id}
    </update>

    <select id="countAll" resultType="int">
        SELECT COUNT(1)
        FROM admin
        WHERE status = 1
    </select>

</mapper>